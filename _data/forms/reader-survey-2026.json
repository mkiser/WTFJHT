          "type": "radio",
          "label": "What best describes your current situation?",
          "required": true,
          "col": "Employment",
          "options": [
            {
              "id": "fulltime",
              "label": "Working full-time"
            },
            {
              "id": "parttime",
              "label": "Part-time or freelance"
            },
            {
              "id": "retired",
              "label": "Retired"
            },
